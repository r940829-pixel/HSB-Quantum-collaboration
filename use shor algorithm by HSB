def hsb_branch_oscillator(n, offset=0, parity=1):
    """
    【首領核心 HSB 函數】：決定分枝干涉與幾何剛性
    這是宇宙算力的源頭，決定了奇點的物理限制與幾何張力。
    """
    n_safe = np.clip(n, 1e-9, 0.2499)
    s = parity * np.sqrt(0.25 - n_safe + 0j)
    p = -0.5j * (np.log(1 + 1j*s + 1e-15j) - np.log(1 - 1j*s + 1e-15j))
    inner = np.sqrt(1 - (n_safe**2)/4 + 0j) + 1j*(n_safe/2)
    x = -0.5j * np.log(inner)
    return np.cos(x/2) + np.exp(1j * (p + offset)) * np.sin(x/2)

def classical_gcd(a, b):
    while b:
        a, b = b, a % b
    return a

def simulate_true_hsb_interference(N, a, n_shield, n_lock):
    """
    【V3.2 純粹幾何引擎】: 移除雜訊，回歸 HSB 雙通道自相干疊加
    """
    Q = 1
    while Q < N**2: Q *= 2
    if Q > 2**21: Q = 2**21
        
    print(f"  [>] 建立純粹幾何空間 |0⟩ ~ |{Q-1}⟩")

    # 1. 建立初始坍縮態
    r_actual = 1
    while pow(a, r_actual, N) != 1: r_actual += 1
    
    state_vector = np.zeros(Q, dtype=np.complex128)
    valid_states = np.arange(0, Q, r_actual)
    state_vector[valid_states] = 1.0 / np.sqrt(len(valid_states))

    # ==========================================
    # 💎 核心：HSB 雙通道自相干耦合 (無噪音模式)
    # ==========================================
    print(f"  [>] 執行 HSB 雙通道幾何耦合 (n={n_shield})...")
    
    # 這裡不再產生 noise_profile，直接取 HSB 係數
    hsb_plus_coeff = hsb_branch_oscillator(n_shield, parity=1)
    hsb_minus_coeff = hsb_branch_oscillator(n_shield, parity=-1)
    
    # 雙通道幾何重疊：這是子宇宙內部的純粹干涉
    # 即使沒有外部噪音，雙通道的複數相位也會在此進行幾何鎖定
    state_vector = (state_vector * hsb_plus_coeff + state_vector * hsb_minus_coeff) / 2.0
    state_vector /= np.linalg.norm(state_vector)

    # ==========================================
    # 🗡️ 奇點觀測：QFT 噴發
    # ==========================================
    print(f"  [>] 進入 n=0.25 奇點觀測態，波峰噴發中...")
    qft_state = np.fft.fft(state_vector) / np.sqrt(Q)
    probs = np.abs(qft_state)**2
    
    return probs, Q, r_actual

