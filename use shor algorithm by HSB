def print_ascii_histogram(probs, limit=10): 
    top_indices = np.argsort(probs)[-limit:][::-1]
    print("     [QFT 測量頻譜掃描 (概率干涉圖)]")
    for idx in top_indices:
        prob = probs[idx]
        bar_length = int(prob * 100000) 
        bar = "█" * min(bar_length, 50)
        print(f"      |{idx:7}⟩ : {bar} ({prob*100:7.4f}%)")

def run_tactical_terminal(a):
    N = TARGET_NUMBER
    print("=" * 65)
    print(" 🌌 GDA-HSB 陣列：動態變頻 Shor 破解引擎 (v3.0 完全體) 🌌")
    print("=" * 65)

    while classical_gcd(a, N) != 1:
        a += 1

    print(f" 【任務參數設定】")
    print(f"  🎯 目標分解數值 (N) : {N}")
    print(f"  🛡️ 護盾剛性 (n_1)   : {N_SHIELD} (雙通道實體干涉)")
    print(f"  🗡️ 鎖定剛性 (n_2)   : {N_LOCK} (奇點觀測期)")
    print("-" * 65)

    probs, Q, r_actual = simulate_true_hsb_interference(N, a, N_SHIELD, N_LOCK)
    
    print(f"  [2] 波函數坍縮測量完成。總狀態數: {Q}")
    print_ascii_histogram(probs, limit=7)
    
    # 尋找第一主波峰 (排除 0)
    top_indices = np.argsort(probs)[::-1]
    measured_peak = top_indices[0] if top_indices[0] != 0 else top_indices[1]
    max_prob = probs[measured_peak]
    
    if max_prob < 0.000001: 
        print("      => ⚠️ loss function (幾何空間崩潰)")
        print("=" * 65)
        return
        
    print(f"      => 鎖定主波峰 |{measured_peak}⟩，概率 {max_prob*100:.4f}%")
    print("-" * 65)
    
    # ==========================================
    # 🧠 V3.0 核心強化：連分數反推週期 (不再依賴作弊)
    # ==========================================
    print(f"  [3] 啟動幾何後處理 (連分數展開)...")
    print(f"      將測量頻率 {measured_peak}/{Q} 轉化為有理數...")
    
    frac = Fraction(int(measured_peak), int(Q)).limit_denominator(N)
    r_candidate = frac.denominator
    
    # 驗證候選週期
    final_r = None
    # 將搜尋倍數從 5 放大到 40，讓它能容納高階諧波的推導
    for m in range(1, 400000):
        if pow(a, r_candidate * m, N) == 1:
            final_r = r_candidate * m
            break

    if final_r:
        print(f"      => 成功由頻譜波峰推導出精確週期 r = {final_r}")
    else:
        print(f"      => ⚠️ 週期推導失敗，需要增加心星剛性。")
        return

    # ==========================================
    # 🎯 第四步：質因數分解
    # ==========================================
    factor1, factor2 = None, None
    if final_r % 2 == 0:
        x = pow(a, final_r // 2, N)
        if x != N - 1:
            factor1 = classical_gcd(x + 1, N)
            factor2 = classical_gcd(x - 1, N)

    print("-" * 65)
    if factor1 and factor2 and factor1 * factor2 == N:
        print(f" ✅ 【破解成功】: 發現質因數 p = {factor1}, q = {factor2}")
        print(f"    [系統驗證] : {factor1} * {factor2} = {N}")
    else:
        print(f" ❌ 【破解失敗】: 週期為奇數或落入無效區間。")
    print("=" * 65)

if __name__ == "__main__":
