import numpy as np
import matplotlib.pyplot as plt
import matplotlib

# --- 介面與字體設定 ---
matplotlib.rcParams['font.family'] = ['Microsoft JhengHei', 'PingFang TC', 'sans-serif']
matplotlib.rcParams['axes.unicode_minus'] = False
